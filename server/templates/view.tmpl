<dialog open>
    <article>
        <header>
            <button aria-label="Close" rel="prev" onclick="closeDialog()"></button>
            <h3>{{ .Image.Title }}</h3>
            <p>{{ .Image.Artist }}</p>
        </header>
        <div aria-busy="true" style="text-align: center;">
            <img src="/image/{{ .Image.ID }}?width=800&height=600"
                 style="display: none"
                 alt="{{ .Image.Title }}"
                 onload="this.style.display = 'block'; this.parentElement.setAttribute('aria-busy', 'false')">
        </div>
        <footer>
            {{ if eq .NextID .Image.ID }}
                <button class="outline" disabled>Selected</button>
            {{ else }}
                <button hx-put="/image/next/{{ .Image.ID }}">Select</button>
            {{ end }}
            <button class="secondary" hx-delete="/image/{{ .Image.ID }}">Delete</button>
        </footer>
    </article>
</dialog>
